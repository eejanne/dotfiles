{
  "$schema": "https://opencode.ai/config.json",
  "theme": "everforest",
  "permission": {
    "bash": {
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny"
    }
  },
  "keybinds": {
    "messages_page_up": "ctrl+b",
    "messages_page_down": "ctrl+f",
    "app_exit": "none"
  }
}
